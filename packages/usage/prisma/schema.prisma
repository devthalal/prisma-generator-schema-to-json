  created_on                    DateTime? /// @desc Date and time when the record was created. @dn Created On @p createdOn
  created_by                    String? /// @desc Unique identifier of the user who created the record. @dn Created By 
  modified_on                   DateTime? /// @desc Date and time when the record was modified. @dn Modified On @p modifiedOn
  modified_by                   String? /// @desc Unique identifier of the user who modified the record. @dn Modified By 
  created_on_behalf_by          String? /// @desc Unique identifier of the delegate user who created the record. @dn Created By (Delegate) 
  modified_on_behalf_by         String? /// @desc Unique identifier of the delegate user who modified the record. @dn Modified By (Delegate) 
  organization_id               String? /// @desc Unique identifier for the organization @dn Organization Id 
  state_code                    String /// @desc Status of the Position @dn Status @p representsStateWith
  status_code                   String? /// @desc Reason for the status of the Position @dn Status Reason
  version_number                Int? ///   @p hasA
  import_sequence_number        Int? /// @desc Sequence number of the import that created this record. @dn Import Sequence Number @p hasA
  overridden_created_on         DateTime? /// @desc Date and time that the record was migrated. @dn Record Created On @p createdOn
  time_zone_rule_version_number Int? /// @desc For internal use only. @dn Time Zone Rule Version Number @p hasA
  utc_conversion_time_zone_code Int? /// @desc Time zone code that was in use when the record was created. @dn UTC Conversion Time Zone Code @p hasA
  name                          String? /// @desc The name of the position. @dn Name @p hasA
  parent_position_id            String? /// @desc Parent position. @dn Parent Position 
