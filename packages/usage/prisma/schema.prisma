generator custom_generator {
  provider = "npx prisma-generator-schema-to-json"
  output   = "../schemaJson"
}

datasource db {
  provider = "postgresql"
  url      = env("PG_URL")
}

enum PosterSource {
  RAW
  GITHUB
}

/// Person with access to the system and who owns objects in the database.
model User {
  system_user_id                 String    @id @default(uuid()) /// @desc Unique identifier for the user. @dn User @p identifiedBy
  organization_id                String /// @desc Unique identifier of the organization associated with the user. @dn Organization  
  business_unit_id               String /// @desc Unique identifier of the business unit with which the user is associated. @dn Business Unit 
  parent_system_user_id          String? /// @desc Unique identifier of the manager of the user. @dn Manager 
  first_name                     String? /// @desc First name of the user. @dn First Name @p hasA
  salutation                     String? /// @desc Salutation for correspondence with the user. @dn Salutation @p hasA
  middle_name                    String? /// @desc Middle name of the user. @dn Middle Name @p hasA
  last_name                      String? /// @desc Last name of the user. @dn Last Name @p hasA
  personal_email_address         String? /// @desc Personal email address of the user. @dn Email 2 @p hasA
  full_name                      String? /// @desc Full name of the user. @dn Full Name @p hasA
  nick_name                      String? /// @desc Nickname of the user. @dn Nickname @p hasA
  title                          String? /// @desc Title of the user. @dn Title @p hasA
  internal_email_address         String? /// @desc Internal email address for the user. @dn Primary Email @p hasA
  job_title                      String? /// @desc Job title of the user. @dn Job Title @p hasA
  mobile_alert_email             String? /// @desc Mobile alert email address for the user. @dn Mobile Alert Email @p hasA
  preferred_email_code           String? /// @desc Preferred email address for the user. @dn Preferred Email @p hasA
  home_phone                     String? /// @desc Home phone number for the user. @dn Home Phone @p hasA
  mobile_phone                   String? /// @desc Mobile phone number for the user. @dn Mobile Phone @p hasA
  preferred_phone_code           String? /// @desc Preferred phone number for the user. @dn Preferred Phone @p hasA
  preferred_address_code         String? /// @desc Preferred address for the user. @dn Preferred Address @p hasA
  photo_url                      String? /// @desc URL for the Website on which a photo of the user is located. @dn Photo URL @p hasA
  domain_name                    String /// @desc Active Directory domain of which the user is a member. @dn User Name @p hasA
  passport_lo                    Int? /// @desc For internal use only. @dn Passport Lo @p hasA
  created_on                     DateTime? /// @desc Date and time when the user was created. @dn Created On @p createdOn
  passport_hi                    Int? /// @desc For internal use only. @dn Passport Hi @p hasA
  disabled_reason                String? /// @desc Reason for disabling the user. @dn Disabled Reason @p hasA
  modified_on                    DateTime? /// @desc Date and time when the user was last modified. @dn Modified On @p modifiedOn
  created_by                     String? /// @desc Unique identifier of the user who created the user. @dn Created By 
  employee_id                    String? /// @desc Employee identifier for the user. @dn Employee @p hasA
  modified_by                    String? /// @desc Unique identifier of the user who last modified the user. @dn Modified By 
  is_disabled                    Boolean? /// @desc Information about whether the user is enabled. @dn Status @p hasA
  government_id                  String? /// @desc Government identifier for the user. @dn Government @p hasA
  version_number                 Int? /// @desc Version number of the user. @dn Version number @p hasA
  skills                         String? /// @desc Skill set of the user. @dn Skills @p hasA
  display_in_service_views       Boolean? /// @desc Whether to display the user in service views. @dn Display in Service Views @p hasA
  calendar_id                    String? /// @desc Fiscal calendar associated with the user. @dn Calendar @p hasA
  setup_user                     Boolean /// @desc Check if user is a setup user. @dn Restricted Access Mode @p hasA
  incoming_email_delivery_method String /// @desc Incoming email delivery method for the user. @dn Incoming Email Delivery Method @p hasA
  outgoing_email_delivery_method String /// @desc Outgoing email delivery method for the user. @dn Outgoing Email Delivery Method @p hasA
  import_sequence_number         Int? /// @desc Unique identifier of the data import or data migration that created this record. @dn Import Sequence Number @p hasA
  access_mode                    String /// @desc Type of user. @dn Access Mode @p hasA
  invite_status_code             String? /// @desc User invitation status. @dn Invitation Status @p hasA
  overridden_created_on          DateTime? /// @desc Date and time that the record was migrated. @dn Record Created On @p createdOn
  utc_conversion_time_zone_code  Int? /// @desc Time zone code that was in use when the record was created. @dn UTC Conversion Time Zone Code @p hasA
  time_zone_rule_version_number  Int? /// @desc For internal use only. @dn Time Zone Rule Version Number @p hasA
  yomi_full_name                 String? /// @desc Pronunciation of the full name of the user, written in phonetic hiragana or katakana characters. @dn Yomi Full Name @p hasA
  yomi_last_name                 String? /// @desc Pronunciation of the last name of the user, written in phonetic hiragana or katakana characters. @dn Yomi Last Name @p hasA
  yomi_middle_name               String? /// @desc Pronunciation of the middle name of the user, written in phonetic hiragana or katakana characters. @dn Yomi Middle Name @p hasA
  yomi_first_name                String? /// @desc Pronunciation of the first name of the user, written in phonetic hiragana or katakana characters. @dn Yomi First Name @p hasA
  is_integration_user            Boolean /// @desc Check if user is an integration user. @dn Integration user mode @p hasA
  default_filters_populated      Boolean /// @desc Indicates if default outlook filters have been populated. @dn Default Filters Populated @p hasA
  created_on_behalf_by           String? /// @desc Unique identifier of the delegate user who created the systemuser. @dn Created By (Delegate) 
  queue_id                       String? /// @desc Unique identifier of the default queue for the user. @dn Default Queue 
  modified_on_behalf_by          String? /// @desc Unique identifier of the delegate user who last modified the systemuser. @dn Modified By (Delegate) 
  email_router_access_approval   String /// @desc Shows the status of the primary email address. @dn Primary Email Status @p hasA
  transaction_currency_id        String? /// @desc Unique identifier of the currency associated with the systemuser. @dn Currency 
  exchange_rate                  Decimal? /// @desc Exchange rate for the currency associated with the systemuser with respect to the base currency. @dn Exchange Rate @p hasA
  cal_type                       String /// @desc License type of user. @dn License Type @p hasA
  is_licensed                    Boolean /// @desc Information about whether the user is licensed. @dn User Licensed @p hasA
  is_sync_with_directory         Boolean /// @desc Information about whether the user is synced with the directory. @dn User Synced @p hasA
  user_license_type              Int /// @desc Shows the type of user license. @dn User License Type @p hasA
  entity_image_id                String? /// @desc For internal use only. @dn Entity Image Id @p hasA
  process_id                     String? /// @desc Shows the ID of the process. @dn Process @p hasA
  stage_id                       String? /// @desc Shows the ID of the stage. @dn Process Stage @p hasA
  position_id                    String? /// @desc User's position in hierarchical security model. @dn Position 
  traversed_path                 String? /// @desc For internal use only. @dn Traversed Path @p hasA
  application_id                 String? /// @desc The identifier for the application. This is used to access data in another application. @dn Application ID @p hasA
  application_id_uri             String? /// @desc The URI used as a unique logical identifier for the external app. This can be used to validate the application. @dn Application ID URI @p hasA
  identity_id                    Int /// @desc For internal use only. @dn Unique user identity id @p hasA
  territory_id                   String? /// @desc Unique identifier of the territory to which the user is assigned. @dn Territory 
  site_id                        String? /// @desc Site at which the user is located. @dn Site 
  primary_address_id             String? ///  @desc User primary address identifier. @dn Primary Address @p hasA

  created_by_user_rel            User?  @relation("created_by_user_rel", fields: [created_by], references: [system_user_id])
  created_by_user                User[] @relation("created_by_user_rel")
  modified_by_user_rel           User?  @relation("modified_by_user_rel", fields: [modified_by], references: [system_user_id])
  modified_by_user               User[] @relation("modified_by_user_rel")
  created_on_behalf_by_user_rel  User?  @relation("created_on_behalf_by_user_rel", fields: [created_on_behalf_by], references: [system_user_id])
  created_on_behalf_by_user      User[] @relation("created_on_behalf_by_user_rel")
  modified_on_behalf_by_user_rel User?  @relation("modified_on_behalf_by_user_rel", fields: [modified_on_behalf_by], references: [system_user_id])
  modified_on_behalf_by_user     User[] @relation("modified_on_behalf_by_user_rel")

  parent_user User?  @relation("parent_user", fields: [parent_system_user_id], references: [system_user_id])
  children    User[] @relation("parent_user")

  queue                            Queue?  @relation("queue", fields: [queue_id], references: [queue_id])
  created_by_user_queue            Queue[] @relation("created_by_user_queue")
  modified_by_user_queue           Queue[] @relation("modified_by_user_queue")
  created_on_behalf_by_user_queue  Queue[] @relation("created_on_behalf_by_user_queue")
  modified_on_behalf_by_user_queue Queue[] @relation("modified_on_behalf_by_user_queue")

  currency                            Currency?  @relation("currency", fields: [transaction_currency_id], references: [transaction_currency_id])
  created_by_user_currency            Currency[] @relation("created_by_user_currency")
  modified_by_user_currency           Currency[] @relation("modified_by_user_currency")
  created_on_behalf_by_user_currency  Currency[] @relation("created_on_behalf_by_user_currency")
  modified_on_behalf_by_user_currency Currency[] @relation("modified_on_behalf_by_user_currency")

  territory                            Territory?  @relation("territory", fields: [territory_id], references: [territory_id])
  created_by_user_territory            Territory[] @relation("created_by_user_territory")
  modified_by_user_territory           Territory[] @relation("modified_by_user_territory")
  created_on_behalf_by_user_territory  Territory[] @relation("created_on_behalf_by_user_territory")
  modified_on_behalf_by_user_territory Territory[] @relation("modified_on_behalf_by_user_territory")

  position                            Position?  @relation("position", fields: [position_id], references: [position_id])
  created_by_user_position            Position[] @relation("created_by_user_position")
  modified_by_user_position           Position[] @relation("modified_by_user_position")
  created_on_behalf_by_user_position  Position[] @relation("created_on_behalf_by_user_position")
  modified_on_behalf_by_user_position Position[] @relation("modified_on_behalf_by_user_position")

  site                            Site?  @relation("site", fields: [site_id], references: [site_id])
  created_by_user_site            Site[] @relation("created_by_user_site")
  modified_by_user_site           Site[] @relation("modified_by_user_site")
  created_on_behalf_by_user_site  Site[] @relation("created_on_behalf_by_user_site")
  modified_on_behalf_by_user_site Site[] @relation("modified_on_behalf_by_user_site")

  primary_address                    Address?  @relation("primary_address", fields: [primary_address_id], references: [address_id])
  address                            Address[] @relation("address")
  created_by_user_address            Address[] @relation("created_by_user_address")
  modified_by_user_address           Address[] @relation("modified_by_user_address")
  created_on_behalf_by_user_address  Address[] @relation("created_on_behalf_by_user_address")
  modified_on_behalf_by_user_address Address[] @relation("modified_on_behalf_by_user_address")

  organization                            Organization?  @relation("organization", fields: [organization_id], references: [organization_id])
  created_by_user_organization            Organization[] @relation("created_by_user_organization")
  modified_by_user_organization           Organization[] @relation("modified_by_user_organization")
  created_on_behalf_by_user_organization  Organization[] @relation("created_on_behalf_by_user_organization")
  modified_on_behalf_by_user_organization Organization[] @relation("modified_on_behalf_by_user_organization")

  business_unit                            BusinessUnit?  @relation("business_unit", fields: [business_unit_id], references: [business_unit_id])
  created_by_user_business_unit            BusinessUnit[] @relation("created_by_user_business_unit")
  modified_by_user_business_unit           BusinessUnit[] @relation("modified_by_user_business_unit")
  created_on_behalf_by_user_business_unit  BusinessUnit[] @relation("created_on_behalf_by_user_business_unit")
  modified_on_behalf_by_user_business_unit BusinessUnit[] @relation("modified_on_behalf_by_user_business_unit")

  contact                            Contact[] @relation("contact")
  created_by_user_contact            Contact[] @relation("created_by_user_contact")
  modified_by_user_contact           Contact[] @relation("modified_by_user_contact")
  created_on_behalf_by_user_contact  Contact[] @relation("created_on_behalf_by_user_contact")
  modified_on_behalf_by_user_contact Contact[] @relation("modified_on_behalf_by_user_contact")
}

// Currency in which a financial transaction is carried out.
model Currency {
  status_code             String? /// @desc Reason for the status of the transaction currency. @dn Status Reason
  modified_on             DateTime? /// @desc Date and time when the transaction currency was last modified. @dn Modified On @p modifiedOn
  state_code              String /// @desc Status of the transaction currency. @dn Status @p representsStateWith
  version_number          Int? /// @desc Version number of the transaction currency. @dn Version Number @p hasA
  modified_by             String? /// @desc Unique identifier of the user who last modified the transaction currency. @dn Modified By 
  import_sequence_number  Int? /// @desc Unique identifier of the data import or data migration that created this record. @dn Import Sequence Number @p hasA
  overridden_created_on   DateTime? /// @desc Date and time that the record was migrated. @dn Record Created On @p createdOn
  created_on              DateTime? /// @desc Date and time when the transaction currency was created. @dn Created On @p createdOn
  transaction_currency_id String    @id @default(uuid()) /// @desc Unique identifier of the transaction currency. @dn Transaction Currency @p identifiedBy
  exchange_rate           Decimal /// @desc Exchange rate between the transaction currency and the base currency. @dn Exchange Rate @p hasA
  currency_symbol         String /// @desc Symbol for the transaction currency. @dn Currency Symbol @p hasA
  currency_name           String /// @desc Name of the transaction currency. @dn Currency Name @p hasA
  created_by              String? /// @desc Unique identifier of the user who created the transaction currency. @dn Created By 
  iso_currency_code       String /// @desc ISO currency code for the transaction currency. @dn Currency Code @p hasA
  organization_id         String /// @desc Unique identifier of the organization associated with the transaction currency. @dn Organization 
  currency_precision      Int /// @desc Number of decimal places that can be used for currency. @dn Currency Precision @p hasA
  created_on_behalf_by    String? /// @desc Unique identifier of the delegate user who created the transactioncurrency. @dn Created By (Delegate) 
  modified_on_behalf_by   String? /// @desc Unique identifier of the delegate user who last modified the transactioncurrency. @dn Modified By (Delegate) 
  entity_image_id         String? /// @desc For internal use only. @dn Entity Image Id @p hasA 

  users                               User[] @relation("currency")
  created_by_user_currency            User?  @relation("created_by_user_currency", fields: [created_by], references: [system_user_id])
  modified_by_user_currency           User?  @relation("modified_by_user_currency", fields: [modified_by], references: [system_user_id])
  created_on_behalf_by_user_currency  User?  @relation("created_on_behalf_by_user_currency", fields: [created_on_behalf_by], references: [system_user_id])
  modified_on_behalf_by_user_currency User?  @relation("modified_on_behalf_by_user_currency", fields: [modified_on_behalf_by], references: [system_user_id])

  organization                Organization?  @relation("organization_currency", fields: [organization_id], references: [organization_id])
  position                    Position[]     @relation("position_currency")
  address                     Address[]      @relation("address_currency")
  business_unit               BusinessUnit[] @relation("business_unit_currency")
  base_currency_organizations Organization[] @relation("base_currency_organization")
}

/// Territory represents sales regions.
model Territory {
  territory_id                  String    @id @default(uuid()) /// @desc Unique identifier of the territory. @dn Territory @p identifiedBy
  created_on                    DateTime? /// @desc Date and time when the record was created. @dn Created On @p createdOn
  created_by                    String? /// @desc Unique identifier of the user who created the territory. @dn Created By 
  modified_on                   DateTime? /// @desc Date and time when the record was modified. @dn Modified On @p modifiedOn
  modified_by                   String? /// @desc Unique identifier of the user who last modified the territory. @dn Modified By 
  created_on_behalf_by          String? /// @desc Unique identifier of the delegate user who created the territory. @dn Created By (Delegate) 
  modified_on_behalf_by         String? /// @desc Unique identifier of the delegate user who last modified the territory. @dn Modified By (Delegate) 
  organization_id               String /// @desc Unique identifier for the organization @dn Organization Id 
  version_number                Int? /// @desc Version Number @dn Version Number @p hasA
  import_sequence_number        Int? /// @desc Sequence number of the import that created this record. @dn Import Sequence Number @p hasA
  overridden_created_on         DateTime? /// @desc Date and time that the record was migrated. @dn Record Created On @p createdOn
  time_zone_rule_version_number Int? /// @desc For internal use only. @dn Time Zone Rule Version Number @p hasA
  utc_conversion_time_zone_code Int? /// @desc Time zone code that was in use when the record was created. @dn UTC Conversion Time Zone Code @p hasA
  name                          String /// @desc Name of the territory. @dn Territory Name @p hasA
  description                   String? /// @desc Description of the territory. @dn Description @p hasA
  manager_id                    String? /// @desc Unique identifier of the manager of the territory. @dn Manager 
  entity_image_id               String? ///   @p hasA
  exchange_rate                 Decimal? /// @desc Exchange rate for the currency associated with the territory with respect to the base currency. @dn Exchange Rate @p hasA
  transaction_currency_id       String? /// @desc Unique identifier of the currency associated with the territory. @dn Currency  

  users                                User[] @relation("territory")
  created_by_user_territory            User?  @relation("created_by_user_territory", fields: [created_by], references: [system_user_id])
  modified_by_user_territory           User?  @relation("modified_by_user_territory", fields: [modified_by], references: [system_user_id])
  created_on_behalf_by_user_territory  User?  @relation("created_on_behalf_by_user_territory", fields: [created_on_behalf_by], references: [system_user_id])
  modified_on_behalf_by_user_territory User?  @relation("modified_on_behalf_by_user_territory", fields: [modified_on_behalf_by], references: [system_user_id])

  organization Organization? @relation("organization_territory", fields: [organization_id], references: [organization_id])
}

/// Queue - A list of records that require action, such as accounts, activities, and cases.
model Queue {
  queue_id                                String    @id @default(uuid()) /// @desc Unique identifier of the queue. @dn Queue @p identifiedBy
  business_unit_id                        String? /// @desc Unique identifier of the business unit with which the queue is associated. @dn Business Unit 
  organization_id                         String /// @desc Unique identifier of the organization associated with the queue. @dn Organization 
  email_address                           String? /// @desc Email address that is associated with the queue. @dn Incoming Email @p hasA
  primary_user_id                         String? /// @desc Unique identifier of the owner of the queue. @dn Owner (deprecated) 
  queue_type_code                         String? /// @desc Type of queue that is automatically assigned when a user or queue is created. The type can be public, private, or work in process. @dn Queue Type @p hasA
  name                                    String? /// @desc Name of the queue. @dn Name @p hasA
  description                             String? /// @desc Description of the queue. @dn Description @p hasA
  queue_semantics                         Int? /// @desc For internal use only. @dn Queue Semantics @p hasA
  created_on                              DateTime? /// @desc Date and time when the queue was created. @dn Created On @p createdOn
  created_by                              String? /// @desc Unique identifier of the user who created the queue record. @dn Created By 
  modified_by                             String? /// @desc Unique identifier of the user who last modified the queue. @dn Modified By 
  modified_on                             DateTime? /// @desc Date and time when the queue was last modified. @dn Modified On @p modifiedOn
  version_number                          Int? /// @desc Version number of the queue. @dn Version Number @p hasA
  ignore_unsolicited_email                Boolean? /// @desc Information that specifies whether a queue is to ignore unsolicited email (deprecated). @dn Convert To Email Activities @p hasA
  is_fax_queue                            Boolean? /// @desc Indication of whether a queue is the fax delivery queue. @dn Fax Queue @p hasA
  email_password                          String? /// @desc This attribute is no longer used. The data is now in the Mailbox.Password attribute. @dn Password (Obsolete) @p hasA
  incoming_email_delivery_method          String /// @desc Incoming email delivery method for the queue. @dn Incoming Email Delivery Method @p hasA
  email_username                          String? /// @desc This attribute is no longer used. The data is now in the Mailbox.UserName attribute. @dn User Name (Obsolete) @p hasA
  outgoing_email_delivery_method          String /// @desc Outgoing email delivery method for the queue. @dn Outgoing Email Delivery Method @p hasA
  allow_email_credentials                 Boolean /// @desc This attribute is no longer used. The data is now in the Mailbox.AllowEmailConnectorToUseCredentials attribute. @dn Allow to Use Credentials for Email Processing (Obsolete) @p hasA
  incoming_email_filtering_method         String /// @desc Convert Incoming Email To Activities @dn Convert Incoming Email To Activities @p hasA
  overridden_created_on                   DateTime? /// @desc Date and time that the record was migrated. @dn Record Created On @p createdOn
  status_code                             String /// @desc Reason for the status of the queue. @dn Status Reason @p [object Object]
  owning_business_unit                    String? /// @desc Unique identifier of the business unit that owns the queue. @dn Owning Business Unit 
  owning_user                             String? /// @desc Unique identifier of the user who owns the queue. @dn Owning User @p hasA
  state_code                              String /// @desc Status of the queue. @dn Status @p representsStateWith
  created_on_behalf_by                    String? /// @desc Unique identifier of the delegate user who created the queue. @dn Created By (Delegate) 
  modified_on_behalf_by                   String? /// @desc Unique identifier of the delegate user who last modified the queue. @dn Modified By (Delegate) 
  number_of_items                         Int? /// @desc Number of Queue items associated with the queue. @dn Queue Items @p hasA
  number_of_members                       Int? /// @desc Number of Members associated with the queue. @dn No. of Members @p hasA
  import_sequence_number                  Int? /// @desc Unique identifier of the data import or data migration that created this record. @dn Import Sequence Number @p hasA
  owning_team                             String? /// @desc Unique identifier of the team who owns the queue. @dn Owning Team @p hasA
  transaction_currency_id                 String? /// @desc Unique identifier of the currency associated with the queue. @dn Currency 
  exchange_rate                           Decimal? /// @desc Exchange rate for the currency associated with the queue with respect to the base currency. @dn Exchange Rate @p hasA
  email_router_access_approval            String /// @desc Shows the status of the primary email address. @dn Primary Email Status @p hasA
  default_mailbox                         String? /// @desc Select the mailbox associated with this queue. @dn Mailbox @p hasA
  entity_image_id                         String? /// @desc For internal use only. @dn Entity Image Id @p hasA
  is_email_address_approved_by_o365_admin Boolean /// @desc Shows the status of approval of the email address by O365 Admin. @dn Email Address O365 Admin Approval Status @p hasA
  queue_view_type                         String /// @desc Select whether the queue is public or private. A public queue can be viewed by all. A private queue can be viewed only by the members added to the queue. @dn Type @p hasA 
  owner_id                                String? // @desc owner's id @dn Owner
  owner_id_type                           String? // @desc The type of owner, either User or Team.  @dn Owner Type

  users                            User[] @relation("queue")
  created_by_user_queue            User?  @relation("created_by_user_queue", fields: [created_by], references: [system_user_id])
  modified_by_user_queue           User?  @relation("modified_by_user_queue", fields: [modified_by], references: [system_user_id])
  created_on_behalf_by_user_queue  User?  @relation("created_on_behalf_by_user_queue", fields: [created_on_behalf_by], references: [system_user_id])
  modified_on_behalf_by_user_queue User?  @relation("modified_on_behalf_by_user_queue", fields: [modified_on_behalf_by], references: [system_user_id])
}

// Position of a user in the hierarchy
