/// Business, division, or department.
model BusinessUnit {
  business_unit_id        String    @id @default(uuid()) /// @desc Unique identifier of the business unit. @dn Business Unit @p identifiedBy
  organization_id         String /// @desc Unique identifier of the organization associated with the business unit. @dn Organization 
  name                    String /// @desc Name of the business unit. @dn Name @p hasA
  description             String? /// @desc Description of the business unit. @dn Description @p hasA
  division_name           String? /// @desc Name of the division to which the business unit belongs. @dn Division @p hasA
  file_as_name            String? /// @desc Alternative name under which the business unit can be filed. @dn File as Name @p hasA
  ticker_symbol           String? /// @desc Stock exchange ticker symbol for the business unit. @dn Ticker Symbol @p hasA
  stock_exchange          String? /// @desc Stock exchange on which the business is listed. @dn Stock Exchange @p hasA
  utc_offset              String? /// @desc UTC offset for the business unit. This is the difference between local time and standard Coordinated Universal Time. @dn UTC Offset @p hasA
  created_on              DateTime? /// @desc Date and time when the business unit was created. @dn Created On @p createdOn
  modified_on             DateTime? /// @desc Date and time when the business unit was last modified. @dn Modified On @p modifiedOn
  credit_limit            String? /// @desc Credit limit for the business unit. @dn Credit Limit @p hasA
  cost_center             String? /// @desc Name of the business unit cost center. @dn Cost Center @p hasA
  web_site_url            String? /// @desc Website URL for the business unit. @dn Website @p hasA
  ftp_site_url            String? /// @desc FTP site URL for the business unit. @dn FTP Site @p hasA
  email_address           String? /// @desc Email address for the business unit. @dn Email @p hasA
  inheritance_mask        Int? /// @desc Inheritance mask for the business unit. @dn Inheritance Mask @p hasA
  created_by              String? /// @desc Unique identifier of the user who created the business unit. @dn Created By  
  modified_by             String? /// @desc Unique identifier of the user who last modified the business unit. @dn Modified By  
  workflow_suspended      Boolean? /// @desc Information about whether workflow or sales process rules have been suspended. @dn Workflow Suspended @p hasA
  parent_business_unit_id String? /// @desc Unique identifier for the parent business unit. @dn Parent Business 
  is_disabled             Boolean? /// @desc Information about whether the business unit is enabled or disabled. @dn Is Disabled @p hasA
  disabled_reason         String? /// @desc Reason for disabling the business unit. @dn Disable Reason @p hasA
  version_number          Int? /// @desc Version number of the business unit. @dn Version number @p hasA
  picture                 String? /// @desc Picture or diagram of the business unit. @dn Picture @p hasA
  calendar_id             String? /// @desc Fiscal calendar associated with the business unit. @dn Calendar @p hasA
  overridden_created_on   DateTime? /// @desc Date and time that the record was migrated. @dn Record Created On @p createdOn
  import_sequence_number  Int? /// @desc Unique identifier of the data import or data migration that created this record. @dn Import Sequence Number @p hasA
  created_on_behalf_by    String? /// @desc Unique identifier of the delegate user who created the businessunit. @dn Created By (Delegate) 
  modified_on_behalf_by   String? /// @desc Unique identifier of the delegate user who last modified the businessunit. @dn Modified By (Delegate) 
  transaction_currency_id String? /// @desc Unique identifier of the currency associated with the businessunit. @dn Currency 
  exchange_rate           Decimal? /// @desc Exchange rate for the currency associated with the businessunit with respect to the base currency. @dn Exchange Rate @p hasA 

  users                                    User[] @relation("business_unit")
  created_by_user_business_unit            User?  @relation("created_by_user_business_unit", fields: [created_by], references: [system_user_id])
  modified_by_user_business_unit           User?  @relation("modified_by_user_business_unit", fields: [modified_by], references: [system_user_id])
  created_on_behalf_by_user_business_unit  User?  @relation("created_on_behalf_by_user_business_unit", fields: [created_on_behalf_by], references: [system_user_id])
  modified_on_behalf_by_user_business_unit User?  @relation("modified_on_behalf_by_user_business_unit", fields: [modified_on_behalf_by], references: [system_user_id])

  organization            Organization?  @relation("organization_business_unit", fields: [organization_id], references: [organization_id])
  parent_business_unit    BusinessUnit?  @relation("parent_business_unit", fields: [parent_business_unit_id], references: [business_unit_id])
  children_business_units BusinessUnit[] @relation("parent_business_unit")

  currency Currency? @relation("business_unit_currency", fields: [transaction_currency_id], references: [transaction_currency_id])
}

