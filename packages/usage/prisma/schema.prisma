  description                   String? /// @desc The description of the position. @dn Description @p hasA
  transaction_currency_id       String? /// @desc Unique identifier of the currency associated with the position. @dn Currency  

  users                               User[] @relation("position")
  created_by_user_position            User?  @relation("created_by_user_position", fields: [created_by], references: [system_user_id])
  modified_by_user_position           User?  @relation("modified_by_user_position", fields: [modified_by], references: [system_user_id])
